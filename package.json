{
  "name": "@strapi/client",
  "version": "1.6.2",
  "description": "The official client library to easily interface with Strapi from your JavaScript/TypeScript project",
  "keywords": [
    "strapi",
    "sdk",
    "library",
    "client",
    "js",
    "ts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/strapi/client.git"
  },
  "license": "SEE LICENSE IN LICENSE",
  "author": {
    "name": "Strapi Solutions SAS",
    "email": "hi@strapi.io",
    "url": "https://strapi.io"
  },
  "maintainers": [
    {
      "name": "Strapi Solutions SAS",
      "email": "hi@strapi.io",
      "url": "https://strapi.io"
    }
  ],
  "browser": "./dist/bundle.browser.iife.min.js",
  "exports": {
    ".": {
      "types": "./dist/exports.d.ts",
      "browser": {
        "import": "./dist/bundle.browser.mjs",
        "require": "./dist/bundle.browser.cjs"
      },
      "node": {
        "require": "./dist/bundle.cjs",
        "import": "./dist/bundle.mjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "./package.json",
    "dist/"
  ],
  "scripts": {
    "build": "rollup --config rollup.config.mjs --failAfterWarnings",
    "build:clean": "pnpm run clean && pnpm run build",
    "clean": "pnpm exec rimraf ./dist",
    "demo": "pnpm exec scripts/demo.sh",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:fix:dry": "eslint . --fix-dry-run",
    "prepare": "husky",
    "format": "prettier --write .",
    "format:write": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "ts:check": "tsc -p tsconfig.build.json --noEmit",
    "watch": "pnpm run build --watch",
    "prepack": "pnpm exec ./scripts/pre-pack.sh"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@commitlint/types": "21.2.0",
    "@rollup/plugin-commonjs": "29.0.3",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-replace": "6.0.3",
    "@rollup/plugin-terser": "1.0.0",
    "@rollup/plugin-typescript": "12.3.0",
    "@types/debug": "4.1.13",
    "@types/node": "^26.0.0",
    "@types/qs": "6.15.1",
    "@typescript-eslint/eslint-plugin": "8.61.1",
    "@typescript-eslint/parser": "8.64.0",
    "@vitest/coverage-v8": "latest",
    "ajv": "8.20.0",
    "eslint": "10.7.0",
    "eslint-plugin-import-x": "4.16.2",
    "fast-uri": "4.0.0",
    "flatted": "3.4.2",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "picomatch": "4.0.4",
    "postcss": "^8.5.10",
    "prettier": "3.9.5",
    "rimraf": "6.1.3",
    "rollup": "4.62.2",
    "typescript": "5.9.3",
    "vite": "8.1.4",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20.18.2 <=24.x.x"
  },
  "dependencies": {
    "debug": "4.4.3",
    "qs": "6.15.3"
  }
}
